{
    "name": "queuemaster/reporter",
    "description": "Enterprise-grade Laravel queue monitoring reporter for QueueMaster.",
    "keywords": ["laravel", "queue", "monitoring", "queuemaster"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "QueueMaster\\Reporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QueueMaster\\Reporter\\QueueMasterReporterServiceProvider"
            ]
        }
    }
}
