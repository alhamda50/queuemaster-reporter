{
    "name": "queuemaster/reporter",
    "description": "A package to report Laravel queue jobs to QueueMaster.",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/queue": "^12.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "autoload": {
        "psr-4": {
            "QueueMaster\\Reporter\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "QueueMaster\\Reporter\\QueueMasterReporterServiceProvider"
            ]
        }
    }
}
